# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Test coverage reports (regenerated by vitest)
coverage

# Local environment files (contain API tokens used by e2e harnesses)
.env
.env.local
.env.*.local

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Private docs (symlinked)
.private/
docs
.claude
.superpowers/
