# Sample environment file for SeaTable e2e harness.
#
# Copy this to `.env` at the repo root (NOT inside tests/e2e/) and fill in
# real values. The harness loads them via tests/e2e/load-env.mjs.
#
# .env is gitignored — never commit a populated copy.

# SeaTable Cloud / self-hosted server URL (no trailing slash). Default
# is the public cloud.
SEATABLE_SERVER_URL=https://cloud.seatable.io

# Base-specific API Token (Read-Write). Create via Base → Advanced
# settings → API Tokens. Each base has its own token; this scopes the
# e2e harness to a single base.
SEATABLE_API_TOKEN=__paste_your_api_token_here__

# The table to write/read against. Defaults to '0000' which is the
# first table in a fresh base. Look it up under "More operations →
# Manage tables" if your base has multiple tables.
SEATABLE_TABLE_ID=0000

# Optional: a view id to scope reads. Leave empty to read every row.
SEATABLE_VIEW_ID=

# Optional: where to drop the per-config sync folder inside the test
# vault. Defaults to "SeaTable-E2E".
SEATABLE_FOLDER_PATH=SeaTable-E2E
